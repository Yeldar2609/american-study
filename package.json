{
  "name": "american-study",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome check --write .",
