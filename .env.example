# Public values provided by Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local: http://localhost:3000
# Firebase App Hosting: set the assigned backend origin in apphosting.yaml.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only. Configure as a Firebase App Hosting backend secret.
# Never add this value to apphosting.yaml or expose it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
